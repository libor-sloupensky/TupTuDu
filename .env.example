APP_NAME="TupTuDu"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=cs
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=cs_CZ

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug

# DB — produkce: MariaDB, host MUSÍ být 127.0.0.1 (ne localhost → jinak [2002] socket)
DB_CONNECTION=mariadb
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=tuptuducom
DB_USERNAME=tuptuducom001
DB_PASSWORD=
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci

# Sdílený hosting bez perzistentních workerů → file/sync
SESSION_DRIVER=file
SESSION_LIFETIME=10080
CACHE_STORE=file
QUEUE_CONNECTION=sync

MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@tuptudu.com"
MAIL_FROM_NAME="${APP_NAME}"

# Admin (Masterteam) — vstup gateován přes IČO master subjektu
MASTER_ICO=07994605

# AI (sdíleno s kalkuliem)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
ANTHROPIC_MODEL_HAIKU=claude-haiku-4-5
ANTHROPIC_MODEL_SONNET=claude-sonnet-4-6
ANTHROPIC_MODEL_OPUS=claude-opus-4-8
VOYAGE_API_KEY=

# Google OAuth — doplnit (credentials + redirect URI v Google Cloud Console)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# Deploy hook token
MIGRATE_TOKEN=
